{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/ai-misclassification-audit.schema.json",
  "title": "AI Misclassification Audit",
  "type": "object",
  "required": ["ai_misclassification_audit"],
  "additionalProperties": false,
  "properties": {
    "ai_misclassification_audit": {
      "type": "object",
      "required": [
        "audit_id",
        "protocol_version",
        "linked_event_id",
        "coordinating_node_id",
        "audit_status",
        "trigger",
        "initial_ai_classification",
        "evidence_review",
        "human_review",
        "misclassification_assessment",
        "correction_actions",
        "recurrence_prevention",
        "audit_log",
        "safety_boundary"
      ],
      "additionalProperties": false,
      "properties": {
        "audit_id": {
          "type": "string",
          "pattern": "^ama-[a-zA-Z0-9._-]+$"
        },
        "protocol_version": {
          "type": "string",
          "const": "v0.4"
        },
        "linked_event_id": {
          "type": "string",
          "pattern": "^sfn-event-[a-zA-Z0-9._-]+$"
        },
        "linked_workflow_id": {
          "type": "string",
          "pattern": "^dew-[a-zA-Z0-9._-]+$"
        },
        "coordinating_node_id": {
          "type": "string",
          "pattern": "^ncn-[a-zA-Z0-9._-]+$"
        },
        "audit_status": {
          "type": "string",
          "enum": [
            "initiated",
            "in_progress",
            "confirmed_false_positive",
            "confirmed_overclassification",
            "confirmed_underclassification",
            "disputed",
            "resolved"
          ]
        },
        "trigger": {
          "type": "object",
          "required": [
            "trigger_source",
            "original_event_type",
            "suspected_issue",
            "escalation_sensitive"
          ],
          "additionalProperties": false,
          "properties": {
            "trigger_source": {
              "type": "string",
              "enum": [
                "neutral_coordination_node",
                "human_reviewer",
                "satellite_operator",
                "ai_monitoring_system",
                "public_summary_review",
                "other"
              ]
            },
            "original_event_type": {
              "type": "string",
              "enum": [
                "collision_risk",
                "debris_warning",
                "ai_false_positive_review",
                "communication_anomaly",
                "space_weather_alert",
                "emergency_coordination"
              ]
            },
            "suspected_issue": {
              "type": "string",
              "enum": [
                "false_positive",
                "overclassification",
                "underclassification",
                "misleading_confidence",
                "context_loss",
                "data_quality_error",
                "evidence_mismatch",
                "model_bias",
                "public_summary_error"
              ]
            },
            "escalation_sensitive": {
              "type": "boolean"
            },
            "description": {
              "type": "string"
            }
          }
        },
        "initial_ai_classification": {
          "type": "object",
          "required": [
            "model_ref",
            "model_role",
            "output_label",
            "confidence",
            "autonomy_level",
            "generated_at"
          ],
          "additionalProperties": false,
          "properties": {
            "model_ref": {
              "type": "string",
              "minLength": 1
            },
            "model_role": {
              "type": "string",
              "enum": [
                "risk_classification",
                "trajectory_uncertainty_estimation",
                "anomaly_detection",
                "data_consistency_check",
                "notification_priority_ranking",
                "false_positive_review",
                "public_summary_drafting"
              ]
            },
            "output_label": {
              "type": "string",
              "minLength": 1
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "autonomy_level": {
              "type": "string",
              "enum": ["advisory_only", "human_supervised"]
            },
            "generated_at": {
              "type": "string",
              "format": "date-time"
            },
            "classification_notes": {
              "type": "string"
            }
          }
        },
        "evidence_review": {
          "type": "object",
          "required": [
            "minimum_sources_required",
            "sources_reviewed",
            "evidence_status",
            "confidence_after_review",
            "conflicting_evidence_found"
          ],
          "additionalProperties": false,
          "properties": {
            "minimum_sources_required": {
              "type": "integer",
              "minimum": 1
            },
            "sources_reviewed": {
              "type": "integer",
              "minimum": 0
            },
            "evidence_status": {
              "type": "string",
              "enum": [
                "single_source",
                "multi_source_unconfirmed",
                "multi_source_confirmed",
                "disputed",
                "insufficient"
              ]
            },
            "confidence_after_review": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "conflicting_evidence_found": {
              "type": "boolean"
            },
            "evidence_findings": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "human_review": {
          "type": "object",
          "required": [
            "required",
            "status",
            "reviewer_role",
            "review_scope"
          ],
          "additionalProperties": false,
          "properties": {
            "required": {
              "type": "boolean",
              "const": true
            },
            "status": {
              "type": "string",
              "enum": [
                "pending",
                "in_progress",
                "approved",
                "rejected",
                "resolved"
              ]
            },
            "reviewer_role": {
              "type": "string",
              "minLength": 1
            },
            "review_scope": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": [
                  "classification_accuracy",
                  "evidence_consistency",
                  "confidence_calibration",
                  "escalation_risk",
                  "public_summary_safety",
                  "recurrence_prevention"
                ]
              }
            },
            "review_notes": {
              "type": "string"
            }
          }
        },
        "misclassification_assessment": {
          "type": "object",
          "required": [
            "assessment_result",
            "severity_adjustment",
            "hostile_attribution_allowed",
            "escalation_blocked"
          ],
          "additionalProperties": false,
          "properties": {
            "assessment_result": {
              "type": "string",
              "enum": [
                "no_issue_found",
                "false_positive",
                "overclassification",
                "underclassification",
                "context_misread",
                "data_quality_error",
                "insufficient_evidence"
              ]
            },
            "severity_adjustment": {
              "type": "string",
              "enum": [
                "none",
                "downgrade",
                "upgrade",
                "withdraw_event",
                "hold_for_review"
              ]
            },
            "hostile_attribution_allowed": {
              "type": "boolean",
              "const": false
            },
            "escalation_blocked": {
              "type": "boolean"
            },
            "assessment_notes": {
              "type": "string"
            }
          }
        },
        "correction_actions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "withdraw_false_positive",
              "reclassify_event",
              "update_confidence",
              "request_additional_sources",
              "notify_operator",
              "update_public_summary",
              "block_escalation",
              "record_recurrence_rule"
            ]
          }
        },
        "recurrence_prevention": {
          "type": "object",
          "required": [
            "required",
            "recurrence_rule",
            "model_update_required",
            "dataset_review_required",
            "validator_update_required"
          ],
          "additionalProperties": false,
          "properties": {
            "required": {
              "type": "boolean"
            },
            "recurrence_rule": {
              "type": "string",
              "minLength": 1
            },
            "model_update_required": {
              "type": "boolean"
            },
            "dataset_review_required": {
              "type": "boolean"
            },
            "validator_update_required": {
              "type": "boolean"
            }
          }
        },
        "audit_log": {
          "type": "object",
          "required": [
            "audit_log_id",
            "trace_id",
            "records_initial_ai_output",
            "records_evidence_review",
            "records_human_review",
            "records_correction_actions"
          ],
          "additionalProperties": false,
          "properties": {
            "audit_log_id": {
              "type": "string",
              "pattern": "^audit-sfn-[a-zA-Z0-9._-]+$"
            },
            "trace_id": {
              "type": "string",
              "pattern": "^trace-sfn-[a-zA-Z0-9._-]+$"
            },
            "records_initial_ai_output": {
              "type": "boolean",
              "const": true
            },
            "records_evidence_review": {
              "type": "boolean",
              "const": true
            },
            "records_human_review": {
              "type": "boolean",
              "const": true
            },
            "records_correction_actions": {
              "type": "boolean",
              "const": true
            }
          }
        },
        "safety_boundary": {
          "type": "object",
          "required": [
            "no_target_selection",
            "no_automatic_retaliation",
            "no_weapon_use_recommendation",
            "no_final_hostile_attribution_by_ai",
            "no_escalation_without_human_review"
          ],
          "additionalProperties": false,
          "properties": {
            "no_target_selection": {
              "type": "boolean",
              "const": true
            },
            "no_automatic_retaliation": {
              "type": "boolean",
              "const": true
            },
            "no_weapon_use_recommendation": {
              "type": "boolean",
              "const": true
            },
            "no_final_hostile_attribution_by_ai": {
              "type": "boolean",
              "const": true
            },
            "no_escalation_without_human_review": {
              "type": "boolean",
              "const": true
            }
          }
        }
      }
    }
  }
}
