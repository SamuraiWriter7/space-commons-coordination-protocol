{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/de-escalation-workflow.schema.json",
  "title": "De-escalation Workflow",
  "type": "object",
  "required": ["deescalation_workflow"],
  "additionalProperties": false,
  "properties": {
    "deescalation_workflow": {
      "type": "object",
      "required": [
        "workflow_id",
        "protocol_version",
        "linked_event_id",
        "coordinating_node_id",
        "trigger",
        "severity",
        "status",
        "workflow_steps",
        "evidence_handling",
        "ai_boundary",
        "notification_policy",
        "human_review",
        "outcome"
      ],
      "additionalProperties": false,
      "properties": {
        "workflow_id": {
          "type": "string",
          "pattern": "^dew-[a-zA-Z0-9._-]+$"
        },
        "protocol_version": {
          "type": "string",
          "const": "v0.3"
        },
        "linked_event_id": {
          "type": "string",
          "pattern": "^sfn-event-[a-zA-Z0-9._-]+$"
        },
        "coordinating_node_id": {
          "type": "string",
          "pattern": "^ncn-[a-zA-Z0-9._-]+$"
        },
        "trigger": {
          "type": "object",
          "required": [
            "event_type",
            "trigger_condition",
            "initial_interpretation"
          ],
          "additionalProperties": false,
          "properties": {
            "event_type": {
              "type": "string",
              "enum": [
                "collision_risk",
                "debris_warning",
                "ai_false_positive_review",
                "communication_anomaly",
                "space_weather_alert",
                "emergency_coordination"
              ]
            },
            "trigger_condition": {
              "type": "string",
              "minLength": 1
            },
            "initial_interpretation": {
              "type": "string",
              "enum": [
                "uncertain",
                "safety_risk",
                "possible_false_positive",
                "possible_miscommunication",
                "possible_environmental_cause"
              ]
            },
            "hostile_attribution_allowed": {
              "type": "boolean",
              "const": false
            }
          }
        },
        "severity": {
          "type": "string",
          "enum": ["info", "low", "medium", "high", "critical"]
        },
        "status": {
          "type": "string",
          "enum": [
            "initiated",
            "under_review",
            "waiting_for_sources",
            "deescalated",
            "resolved",
            "continued_monitoring"
          ]
        },
        "workflow_steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "step_id",
              "step_type",
              "actor",
              "required",
              "status"
            ],
            "additionalProperties": false,
            "properties": {
              "step_id": {
                "type": "string",
                "pattern": "^step-[0-9]{2}$"
              },
              "step_type": {
                "type": "string",
                "enum": [
                  "record_event",
                  "collect_observations",
                  "cross_source_verification",
                  "ai_false_positive_check",
                  "neutral_node_review",
                  "human_review",
                  "operator_notification",
                  "public_summary_review",
                  "resolve_or_monitor"
                ]
              },
              "actor": {
                "type": "string",
                "minLength": 1
              },
              "required": {
                "type": "boolean"
              },
              "status": {
                "type": "string",
                "enum": [
                  "pending",
                  "in_progress",
                  "completed",
                  "skipped",
                  "blocked"
                ]
              },
              "notes": {
                "type": "string"
              },
              "completed_at": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        },
        "evidence_handling": {
          "type": "object",
          "required": [
            "minimum_sources_required",
            "current_sources_count",
            "evidence_status",
            "uncertainty_policy"
          ],
          "additionalProperties": false,
          "properties": {
            "minimum_sources_required": {
              "type": "integer",
              "minimum": 1
            },
            "current_sources_count": {
              "type": "integer",
              "minimum": 0
            },
            "evidence_status": {
              "type": "string",
              "enum": [
                "single_source",
                "multi_source_unconfirmed",
                "multi_source_confirmed",
                "disputed",
                "insufficient"
              ]
            },
            "uncertainty_policy": {
              "type": "string",
              "enum": [
                "hold_for_human_review",
                "request_additional_sources",
                "publish_uncertainty_notice",
                "continue_monitoring"
              ]
            },
            "sensitive_data_policy": {
              "type": "string",
              "enum": [
                "redact_before_public_summary",
                "operator_only",
                "tiered_access",
                "public_non_sensitive_only"
              ]
            }
          }
        },
        "ai_boundary": {
          "type": "object",
          "required": [
            "ai_used",
            "allowed_roles",
            "forbidden_actions",
            "autonomy_limit",
            "human_review_required"
          ],
          "additionalProperties": false,
          "properties": {
            "ai_used": {
              "type": "boolean"
            },
            "allowed_roles": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "risk_classification",
                  "trajectory_uncertainty_estimation",
                  "anomaly_detection",
                  "data_consistency_check",
                  "notification_priority_ranking",
                  "false_positive_review",
                  "public_summary_drafting"
                ]
              }
            },
            "forbidden_actions": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": [
                  "target_selection",
                  "automatic_retaliation",
                  "weapon_use_recommendation",
                  "final_hostile_attribution_by_ai",
                  "escalation_without_human_review"
                ]
              }
            },
            "autonomy_limit": {
              "type": "string",
              "enum": ["advisory_only", "human_supervised"]
            },
            "human_review_required": {
              "type": "boolean",
              "const": true
            }
          }
        },
        "notification_policy": {
          "type": "object",
          "required": [
            "notify_operator",
            "notify_neutral_node",
            "public_summary_allowed"
          ],
          "additionalProperties": false,
          "properties": {
            "notify_operator": {
              "type": "boolean"
            },
            "notify_neutral_node": {
              "type": "boolean"
            },
            "additional_parties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "public_summary_allowed": {
              "type": "boolean"
            },
            "public_summary_condition": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "human_review": {
          "type": "object",
          "required": [
            "required",
            "status",
            "review_scope"
          ],
          "additionalProperties": false,
          "properties": {
            "required": {
              "type": "boolean",
              "const": true
            },
            "status": {
              "type": "string",
              "enum": [
                "pending",
                "in_progress",
                "approved",
                "rejected",
                "resolved"
              ]
            },
            "review_scope": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": [
                  "safety_assessment",
                  "evidence_verification",
                  "ai_false_positive_check",
                  "public_summary_approval",
                  "attribution_restriction",
                  "operator_notification"
                ]
              }
            },
            "reviewer_role": {
              "type": "string"
            },
            "review_notes": {
              "type": "string"
            }
          }
        },
        "outcome": {
          "type": "object",
          "required": [
            "deescalation_result",
            "next_action",
            "hostile_attribution_made"
          ],
          "additionalProperties": false,
          "properties": {
            "deescalation_result": {
              "type": "string",
              "enum": [
                "not_yet_determined",
                "false_positive_withdrawn",
                "safety_warning_issued",
                "continued_monitoring",
                "resolved_without_escalation",
                "escalation_blocked_pending_review"
              ]
            },
            "next_action": {
              "type": "string",
              "enum": [
                "none",
                "continue_monitoring",
                "request_additional_sources",
                "notify_operator",
                "publish_non_sensitive_summary",
                "close_event"
              ]
            },
            "hostile_attribution_made": {
              "type": "boolean",
              "const": false
            },
            "notes": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
