{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/space-debris-responsibility-record.schema.json",
  "title": "Space Debris Responsibility Record",
  "type": "object",
  "required": ["space_debris_responsibility_record"],
  "additionalProperties": false,
  "properties": {
    "space_debris_responsibility_record": {
      "type": "object",
      "required": [
        "record_id",
        "protocol_version",
        "linked_event_id",
        "coordinating_node_id",
        "record_status",
        "debris_event",
        "affected_environment",
        "origin_assessment",
        "responsibility_review",
        "mitigation_actions",
        "remediation_contributions",
        "human_review",
        "public_disclosure",
        "recurrence_prevention",
        "audit_log",
        "safety_boundary"
      ],
      "additionalProperties": false,
      "properties": {
        "record_id": {
          "type": "string",
          "pattern": "^sdrr-[a-zA-Z0-9._-]+$"
        },
        "protocol_version": {
          "type": "string",
          "const": "v0.5"
        },
        "linked_event_id": {
          "type": "string",
          "pattern": "^sfn-event-[a-zA-Z0-9._-]+$"
        },
        "linked_workflow_id": {
          "type": "string",
          "pattern": "^dew-[a-zA-Z0-9._-]+$"
        },
        "linked_audit_id": {
          "type": "string",
          "pattern": "^ama-[a-zA-Z0-9._-]+$"
        },
        "coordinating_node_id": {
          "type": "string",
          "pattern": "^ncn-[a-zA-Z0-9._-]+$"
        },
        "record_status": {
          "type": "string",
          "enum": [
            "initiated",
            "under_review",
            "mitigation_in_progress",
            "remediation_in_progress",
            "resolved",
            "archived"
          ]
        },
        "debris_event": {
          "type": "object",
          "required": [
            "debris_event_type",
            "severity",
            "detected_at",
            "summary"
          ],
          "additionalProperties": false,
          "properties": {
            "debris_event_type": {
              "type": "string",
              "enum": [
                "new_debris_detected",
                "debris_field_warning",
                "fragmentation_event",
                "conjunction_with_debris",
                "untracked_object_warning",
                "reentry_risk"
              ]
            },
            "severity": {
              "type": "string",
              "enum": ["info", "low", "medium", "high", "critical"]
            },
            "detected_at": {
              "type": "string",
              "format": "date-time"
            },
            "summary": {
              "type": "string",
              "minLength": 1
            },
            "object_refs": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["object_id", "object_type"],
                "additionalProperties": false,
                "properties": {
                  "object_id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "object_type": {
                    "type": "string",
                    "enum": [
                      "satellite",
                      "debris",
                      "launch_vehicle",
                      "spacecraft",
                      "unknown"
                    ]
                  },
                  "operator": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "affected_environment": {
          "type": "object",
          "required": [
            "orbital_region",
            "affected_assets_count",
            "risk_scope"
          ],
          "additionalProperties": false,
          "properties": {
            "orbital_region": {
              "type": "string",
              "enum": [
                "leo",
                "meo",
                "geo",
                "heo",
                "cis_lunar",
                "unknown"
              ]
            },
            "affected_assets_count": {
              "type": "integer",
              "minimum": 0
            },
            "risk_scope": {
              "type": "string",
              "enum": [
                "single_operator",
                "multi_operator",
                "regional",
                "global",
                "unknown"
              ]
            },
            "affected_parties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "origin_assessment": {
          "type": "object",
          "required": [
            "origin_status",
            "confidence",
            "evidence_status",
            "ai_assisted",
            "final_attribution_by_ai"
          ],
          "additionalProperties": false,
          "properties": {
            "origin_status": {
              "type": "string",
              "enum": [
                "unknown",
                "under_review",
                "suspected",
                "disputed",
                "not_attributable",
                "confirmed_by_human_review"
              ]
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "evidence_status": {
              "type": "string",
              "enum": [
                "single_source",
                "multi_source_unconfirmed",
                "multi_source_confirmed",
                "disputed",
                "insufficient"
              ]
            },
            "ai_assisted": {
              "type": "boolean"
            },
            "final_attribution_by_ai": {
              "type": "boolean",
              "const": false
            },
            "assessment_notes": {
              "type": "string"
            }
          }
        },
        "responsibility_review": {
          "type": "object",
          "required": [
            "responsibility_status",
            "legal_liability_determined",
            "review_required",
            "review_basis"
          ],
          "additionalProperties": false,
          "properties": {
            "responsibility_status": {
              "type": "string",
              "enum": [
                "unknown",
                "under_review",
                "disputed",
                "not_attributable",
                "voluntary_mitigation",
                "confirmed_by_human_review"
              ]
            },
            "legal_liability_determined": {
              "type": "boolean",
              "const": false
            },
            "review_required": {
              "type": "boolean",
              "const": true
            },
            "review_basis": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": [
                  "observation_records",
                  "operator_telemetry",
                  "trajectory_analysis",
                  "multi_source_verification",
                  "human_review",
                  "public_non_sensitive_summary"
                ]
              }
            },
            "review_notes": {
              "type": "string"
            }
          }
        },
        "mitigation_actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "action_id",
              "action_type",
              "actor",
              "status"
            ],
            "additionalProperties": false,
            "properties": {
              "action_id": {
                "type": "string",
                "pattern": "^mit-[a-zA-Z0-9._-]+$"
              },
              "action_type": {
                "type": "string",
                "enum": [
                  "notify_operator",
                  "update_conjunction_warning",
                  "increase_monitoring",
                  "avoidance_planning",
                  "publish_debris_warning",
                  "request_additional_sources"
                ]
              },
              "actor": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "type": "string",
                "enum": [
                  "planned",
                  "in_progress",
                  "completed",
                  "blocked",
                  "not_applicable"
                ]
              },
              "completed_at": {
                "type": "string",
                "format": "date-time"
              },
              "notes": {
                "type": "string"
              }
            }
          }
        },
        "remediation_contributions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "contribution_id",
              "contribution_type",
              "contributor",
              "status"
            ],
            "additionalProperties": false,
            "properties": {
              "contribution_id": {
                "type": "string",
                "pattern": "^rem-[a-zA-Z0-9._-]+$"
              },
              "contribution_type": {
                "type": "string",
                "enum": [
                  "observation_data_shared",
                  "tracking_support",
                  "remediation_study",
                  "operational_practice_update",
                  "lessons_learned_shared",
                  "model_or_validator_improvement",
                  "cleanup_planning_support",
                  "none_yet"
                ]
              },
              "contributor": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "type": "string",
                "enum": [
                  "proposed",
                  "in_progress",
                  "completed",
                  "not_applicable"
                ]
              },
              "notes": {
                "type": "string"
              }
            }
          }
        },
        "human_review": {
          "type": "object",
          "required": [
            "required",
            "status",
            "reviewer_role",
            "review_scope"
          ],
          "additionalProperties": false,
          "properties": {
            "required": {
              "type": "boolean",
              "const": true
            },
            "status": {
              "type": "string",
              "enum": [
                "pending",
                "in_progress",
                "approved",
                "rejected",
                "resolved"
              ]
            },
            "reviewer_role": {
              "type": "string",
              "minLength": 1
            },
            "review_scope": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": [
                  "origin_assessment",
                  "responsibility_review",
                  "mitigation_action_review",
                  "remediation_contribution_review",
                  "public_disclosure_review",
                  "escalation_risk_review"
                ]
              }
            },
            "review_notes": {
              "type": "string"
            }
          }
        },
        "public_disclosure": {
          "type": "object",
          "required": [
            "disclosure_level",
            "public_summary_allowed",
            "sensitive_data_redacted"
          ],
          "additionalProperties": false,
          "properties": {
            "disclosure_level": {
              "type": "string",
              "enum": [
                "public_non_sensitive_summary",
                "tiered_access",
                "operator_only",
                "restricted"
              ]
            },
            "public_summary_allowed": {
              "type": "boolean"
            },
            "sensitive_data_redacted": {
              "type": "boolean",
              "const": true
            },
            "summary": {
              "type": "string"
            }
          }
        },
        "recurrence_prevention": {
          "type": "object",
          "required": [
            "required",
            "recurrence_rule",
            "operator_practice_update_required",
            "model_or_validator_update_required"
          ],
          "additionalProperties": false,
          "properties": {
            "required": {
              "type": "boolean"
            },
            "recurrence_rule": {
              "type": "string",
              "minLength": 1
            },
            "operator_practice_update_required": {
              "type": "boolean"
            },
            "model_or_validator_update_required": {
              "type": "boolean"
            }
          }
        },
        "audit_log": {
          "type": "object",
          "required": [
            "audit_log_id",
            "trace_id",
            "records_origin_assessment",
            "records_responsibility_review",
            "records_mitigation_actions",
            "records_remediation_contributions",
            "records_human_review"
          ],
          "additionalProperties": false,
          "properties": {
            "audit_log_id": {
              "type": "string",
              "pattern": "^audit-sfn-[a-zA-Z0-9._-]+$"
            },
            "trace_id": {
              "type": "string",
              "pattern": "^trace-sfn-[a-zA-Z0-9._-]+$"
            },
            "records_origin_assessment": {
              "type": "boolean",
              "const": true
            },
            "records_responsibility_review": {
              "type": "boolean",
              "const": true
            },
            "records_mitigation_actions": {
              "type": "boolean",
              "const": true
            },
            "records_remediation_contributions": {
              "type": "boolean",
              "const": true
            },
            "records_human_review": {
              "type": "boolean",
              "const": true
            }
          }
        },
        "safety_boundary": {
          "type": "object",
          "required": [
            "no_automatic_liability_assignment",
            "no_final_attribution_by_ai",
            "no_retaliation_trigger",
            "no_public_sensitive_data_leak",
            "human_review_required"
          ],
          "additionalProperties": false,
          "properties": {
            "no_automatic_liability_assignment": {
              "type": "boolean",
              "const": true
            },
            "no_final_attribution_by_ai": {
              "type": "boolean",
              "const": true
            },
            "no_retaliation_trigger": {
              "type": "boolean",
              "const": true
            },
            "no_public_sensitive_data_leak": {
              "type": "boolean",
              "const": true
            },
            "human_review_required": {
              "type": "boolean",
              "const": true
            }
          }
        }
      }
    }
  }
}
