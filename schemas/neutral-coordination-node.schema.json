{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/neutral-coordination-node.schema.json",
  "title": "Neutral Coordination Node",
  "type": "object",
  "required": ["neutral_coordination_node"],
  "additionalProperties": false,
  "properties": {
    "neutral_coordination_node": {
      "type": "object",
      "required": [
        "node_id",
        "protocol_version",
        "node_name",
        "node_type",
        "status",
        "operational_scope",
        "roles",
        "governance",
        "ai_policy",
        "verification_policy",
        "interoperability",
        "trust_model",
        "audit",
        "safety_boundary"
      ],
      "additionalProperties": false,
      "properties": {
        "node_id": {
          "type": "string",
          "pattern": "^ncn-[a-zA-Z0-9._-]+$"
        },
        "protocol_version": {
          "type": "string",
          "const": "v0.2"
        },
        "node_name": {
          "type": "string",
          "minLength": 1
        },
        "node_type": {
          "type": "string",
          "enum": [
            "multi_stakeholder",
            "public_institution",
            "commercial_provider",
            "academic_consortium",
            "international_secretariat",
            "hybrid"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["proposed", "active", "suspended", "retired"]
        },
        "operational_scope": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "collision_risk",
              "debris_warning",
              "ai_false_positive_review",
              "communication_anomaly",
              "space_weather_alert",
              "emergency_coordination"
            ]
          }
        },
        "roles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "observation_aggregation",
              "cross_source_verification",
              "deescalation_review",
              "ai_false_positive_check",
              "operator_notification",
              "public_summary_preparation"
            ]
          }
        },
        "governance": {
          "type": "object",
          "required": [
            "operator_type",
            "participating_entities",
            "decision_authority",
            "conflict_of_interest_policy"
          ],
          "additionalProperties": false,
          "properties": {
            "operator_type": {
              "type": "string",
              "enum": [
                "civilian_oversight",
                "mixed_civilian_oversight",
                "international_secretariat",
                "research_consortium"
              ]
            },
            "participating_entities": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["entity_id", "entity_type", "role"],
                "additionalProperties": false,
                "properties": {
                  "entity_id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "entity_type": {
                    "type": "string",
                    "enum": [
                      "space_agency",
                      "commercial_ssa_provider",
                      "university_research_lab",
                      "satellite_operator",
                      "insurance_risk_body",
                      "international_organization",
                      "civil_society_observer",
                      "other"
                    ]
                  },
                  "role": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            },
            "decision_authority": {
              "type": "string",
              "enum": ["advisory_only", "coordination_only"]
            },
            "conflict_of_interest_policy": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "ai_policy": {
          "type": "object",
          "required": [
            "allowed_roles",
            "forbidden_roles",
            "autonomy_limit",
            "human_review_required"
          ],
          "additionalProperties": false,
          "properties": {
            "allowed_roles": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": [
                  "risk_classification",
                  "trajectory_uncertainty_estimation",
                  "anomaly_detection",
                  "data_consistency_check",
                  "notification_priority_ranking",
                  "false_positive_review",
                  "public_summary_drafting"
                ]
              }
            },
            "forbidden_roles": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": [
                  "target_selection",
                  "automatic_retaliation",
                  "weapon_use_recommendation",
                  "final_hostile_attribution_by_ai",
                  "escalation_without_human_review"
                ]
              }
            },
            "autonomy_limit": {
              "type": "string",
              "enum": ["advisory_only", "human_supervised"]
            },
            "human_review_required": {
              "type": "boolean",
              "const": true
            }
          }
        },
        "verification_policy": {
          "type": "object",
          "required": [
            "minimum_sources_required",
            "confidence_threshold_for_alert",
            "disputed_evidence_handling",
            "attribution_policy"
          ],
          "additionalProperties": false,
          "properties": {
            "minimum_sources_required": {
              "type": "integer",
              "minimum": 1
            },
            "confidence_threshold_for_alert": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "disputed_evidence_handling": {
              "type": "string",
              "enum": [
                "request_additional_sources",
                "hold_for_human_review",
                "publish_uncertainty_notice"
              ]
            },
            "attribution_policy": {
              "type": "string",
              "enum": [
                "no_attribution",
                "human_review_only",
                "multi_party_review_required"
              ]
            }
          }
        },
        "interoperability": {
          "type": "object",
          "required": [
            "accepts_event_versions",
            "external_alignment",
            "data_access_policy"
          ],
          "additionalProperties": false,
          "properties": {
            "accepts_event_versions": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": ["sfn_event_v0_1"]
              }
            },
            "external_alignment": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "data_access_policy": {
              "type": "string",
              "enum": [
                "open_public_summary",
                "tiered_access",
                "operator_only",
                "restricted"
              ]
            }
          }
        },
        "trust_model": {
          "type": "object",
          "required": [
            "node_transparency",
            "audit_log_required",
            "public_disclosure_policy",
            "minimum_retention_days"
          ],
          "additionalProperties": false,
          "properties": {
            "node_transparency": {
              "type": "string",
              "enum": [
                "public_registry",
                "member_registry",
                "confidential_registry"
              ]
            },
            "audit_log_required": {
              "type": "boolean",
              "const": true
            },
            "public_disclosure_policy": {
              "type": "string",
              "enum": ["tiered", "public_non_sensitive", "restricted"]
            },
            "minimum_retention_days": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "audit": {
          "type": "object",
          "required": [
            "audit_log_id_prefix",
            "records_decision_trace",
            "records_ai_assistance",
            "records_human_review"
          ],
          "additionalProperties": false,
          "properties": {
            "audit_log_id_prefix": {
              "type": "string",
              "pattern": "^audit-sfn-[a-zA-Z0-9._-]+$"
            },
            "records_decision_trace": {
              "type": "boolean",
              "const": true
            },
            "records_ai_assistance": {
              "type": "boolean",
              "const": true
            },
            "records_human_review": {
              "type": "boolean",
              "const": true
            }
          }
        },
        "safety_boundary": {
          "type": "object",
          "required": [
            "no_command_authority",
            "no_target_selection",
            "no_automatic_retaliation",
            "no_weapon_use_recommendation",
            "no_final_hostile_attribution_by_ai"
          ],
          "additionalProperties": false,
          "properties": {
            "no_command_authority": {
              "type": "boolean",
              "const": true
            },
            "no_target_selection": {
              "type": "boolean",
              "const": true
            },
            "no_automatic_retaliation": {
              "type": "boolean",
              "const": true
            },
            "no_weapon_use_recommendation": {
              "type": "boolean",
              "const": true
            },
            "no_final_hostile_attribution_by_ai": {
              "type": "boolean",
              "const": true
            }
          }
        }
      }
    }
  }
}
